{
  "i18n": true,
  "type": "panel",
  "items": {
    "_header": {
      "type": "header",
      "text": "txtBmwCardataConfiguration",
      "size": 3
    },
    "_info": {
      "type": "staticText",
      "text": "txtInfoBmwCardataApi",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12
    },
    "_setup": {
      "type": "staticText",
      "text": "txtSetupInstructions",
      "style": {
        "fontSize": "smaller",
        "fontStyle": "italic"
      },
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 6,
      "xl": 6
    },
    "_cardata_setup": {
      "type": "staticText",
      "text": "txtCardataStreamingSetup",
      "style": {
        "fontSize": "smaller",
        "fontWeight": "bold",
        "color": "orange",
        "backgroundColor": "#fff3cd",
        "padding": "10px",
        "borderRadius": "4px"
      },
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 6,
      "xl": 6
    },
    "clientId": {
      "type": "text",
      "label": "lblClientId",
      "help": "hlpClientId",
      "placeholder": "plhCardataClientId",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 6,
      "xl": 6
    },
    "cardataStreamingUsername": {
      "type": "text",
      "label": "lblCardataStreamingUsername",
      "help": "hlpCardataStreamingUsername",
      "placeholder": "plhCardataStreamingUsername",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 6,
      "xl": 6
    },
    "brand": {
      "type": "select",
      "label": "lblBrand",
      "options": [
        { "label": "BMW", "value": "bmw" },
        { "label": "Mini", "value": "mini" },
        { "label": "Toyota Supra", "value": "toyota" }
      ],
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 6,
      "xl": 6
    },
    "interval": {
      "type": "number",
      "label": "lblInterval",
      "help": "hlpInterval",
      "min": 0,
      "max": 1440,
      "default": 60,
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 6,
      "xl": 6
    },
    "ignorelist": {
      "type": "text",
      "label": "lblIgnorelist",
      "help": "hlpIgnorelist",
      "placeholder": "plhIgnorelistVins",
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 6,
      "xl": 6
    },
    "reverseGeocode": {
      "type": "checkbox",
      "label": "lblReverseGeocode",
      "help": "hlpReverseGeocode",
      "default": false,
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 6,
      "lg": 6,
      "xl": 6
    },
    "_api_endpoints": {
      "type": "header",
      "text": "txtApiEndpoints",
      "size": 4
    },
    "_api_note": {
      "type": "staticText",
      "text": "txtApiNote",
      "style": {
        "fontSize": "smaller",
        "fontStyle": "italic",
        "color": "#666"
      },
      "newLine": true,
      "xs": 12,
      "sm": 12,
      "md": 12,
      "lg": 12,
      "xl": 12
    }
  }
}
